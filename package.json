{
  "name": "microvm-agent",
  "version": "0.0.0",
  "description": "Safely run an AI agent prompt inside a Firecracker microVM as a GitHub Action.",
  "type": "module",
  "scripts": {
    "build": "ncc build src/main.js -o dist",
    "test": "node --test test/*.test.js && npm run test:gateway",
    "test:gateway": "python3 test/gw_addon_test.py"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "private": false,
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/tool-cache": "^4.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.3"
  }
}
